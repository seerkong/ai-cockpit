<plan>
  <metadata>
    <track_id>add-stalled-session-auto-recover</track_id>
    <track_name>会话卡住自动恢复与右侧 Settings Tab</track_name>
    <goal>当会话 busy|retry 且长时间无消息进展时自动 abort 并发送“请继续”，并在 /work 右侧面板新增可配置 Settings Tab（默认启用，默认 5 分钟）。</goal>
    <created_at>2026-03-01T10:52:34Z</created_at>
    <updated_at>2026-03-01T11:47:26Z</updated_at>
    <status>in_progress</status>
    <commit_mode>manual</commit_mode>
  </metadata>

  <phases>
    <phase id="P1" name="Settings Tab 与配置持久化">
      <goal>在 /work 右侧面板新增 Settings Tab，并把相关可控项统一收纳；配置默认值正确且可持久化。</goal>
      <estimated_days>1</estimated_days>
      <tasks>
        <task id="T1.1" name="新增用户设置存储（可持久化）" status="DONE" priority="P0" estimated_days="0.5">
          新增用于 /work 运行控制的用户设置存储，并支持持久化（刷新页面后保持）。至少包含：stalled auto-recover enabled + timeoutMinutes。
          <acceptance_criteria>
            <criterion id="T1.1-AC1" checked="true">设置可读写且刷新后保持</criterion>
            <criterion id="T1.1-AC2" checked="true">默认值：enabled=true，timeoutMinutes=5</criterion>
          </acceptance_criteria>
          <subtasks>
            <subtask id="T1.1.1" name="编写失败测试用例" status="DONE" estimated_hours="1"/>
            <subtask id="T1.1.2" name="实现设置存储与持久化" status="DONE" estimated_hours="2"/>
            <subtask id="T1.1.3" name="重构与类型收敛" status="DONE" estimated_hours="1"/>
          </subtasks>
        </task>

        <task id="T1.2" name="新增 RightPanel Settings Tab" status="DONE" priority="P0" estimated_days="0.5">
          在 dockview 右侧面板新增 Settings tab，并将现有可控开关统一移入：autoAcceptPermissions、codumentAutoRefreshEnabled、stalled auto-recover。
          <dependencies>T1.1</dependencies>
          <acceptance_criteria>
            <criterion id="T1.2-AC1" checked="true">Settings tab 可见且默认渲染正确</criterion>
            <criterion id="T1.2-AC2" checked="true">现有开关迁移后行为不变</criterion>
          </acceptance_criteria>
          <subtasks>
            <subtask id="T1.2.1" name="编写失败测试用例" status="DONE" estimated_hours="1"/>
            <subtask id="T1.2.2" name="实现 Settings tab UI 与注入/回调" status="DONE" estimated_hours="2"/>
            <subtask id="T1.2.3" name="迁移并整合已有开关" status="DONE" estimated_hours="2"/>
          </subtasks>
        </task>
      </tasks>
      <gate_criteria>
        <criterion>Settings tab 可见且默认值正确</criterion>
        <criterion>基础单元测试通过</criterion>
      </gate_criteria>
    </phase>

    <phase id="P2" name="Watchdog 检测与恢复动作">
      <goal>实现“无进展卡住自动恢复”：fingerprint 检测、暂停条件、防循环、abort→wait idle→请继续。</goal>
      <estimated_days>2</estimated_days>
      <tasks>
        <task id="T2.1" name="消息指纹与活跃度判定" status="DONE" priority="P0" estimated_days="1">
          定义并实现 message fingerprint 计算与 lastActivityAt 更新策略：只有 fingerprint 变化才视为有进展。
          <acceptance_criteria>
            <criterion id="T2.1-AC1" checked="true">流式 text delta 或 tool 状态变化可更新活跃时间</criterion>
            <criterion id="T2.1-AC2" checked="true">仅轮询刷新不导致误判为有进展</criterion>
          </acceptance_criteria>
          <subtasks>
            <subtask id="T2.1.1" name="编写失败测试用例" status="DONE" estimated_hours="2"/>
            <subtask id="T2.1.2" name="实现 fingerprint 算法" status="DONE" estimated_hours="3"/>
            <subtask id="T2.1.3" name="重构与边界条件覆盖" status="DONE" estimated_hours="2"/>
          </subtasks>
        </task>

        <task id="T2.2" name="watchdog 定时器与暂停条件" status="DONE" priority="P0" estimated_days="1">
          实现 watchdog：当 session status 为 busy|retry 且 fingerprint 超时未变化时触发。支持暂停条件：pending permission、pending question、长工具运行中、消息刷新失败/离线。
          <dependencies>T2.1</dependencies>
          <acceptance_criteria>
            <criterion id="T2.2-AC1" checked="true">满足暂停条件时不会触发自动恢复</criterion>
            <criterion id="T2.2-AC2" checked="true">启用/禁用与 timeoutMinutes 修改即时生效</criterion>
          </acceptance_criteria>
          <subtasks>
            <subtask id="T2.2.1" name="编写失败测试用例" status="DONE" estimated_hours="2"/>
            <subtask id="T2.2.2" name="实现 watchdog 轮询与暂停条件" status="DONE" estimated_hours="4"/>
            <subtask id="T2.2.3" name="重构：单飞锁与状态机整理" status="DONE" estimated_hours="2"/>
          </subtasks>
        </task>

        <task id="T2.3" name="恢复动作：abort→wait idle→请继续" status="DONE" priority="P0" estimated_days="1">
          实现恢复动作序列：触发前强制 refresh 确认仍卡住；发送 abort；等待 idle（上限 60s）；发送 prompt“请继续”。加入防循环 guardrails（cooldown、最大尝试次数）。
          <dependencies>T2.2</dependencies>
          <acceptance_criteria>
            <criterion id="T2.3-AC1" checked="true">卡住超过阈值后自动 abort 并发送“请继续”</criterion>
            <criterion id="T2.3-AC2" checked="true">cooldown/最大尝试防止循环触发</criterion>
            <criterion id="T2.3-AC3" checked="true">UI 可观测：显示自动恢复发生（时间/提示）</criterion>
          </acceptance_criteria>
          <subtasks>
            <subtask id="T2.3.1" name="编写失败测试用例" status="DONE" estimated_hours="2"/>
            <subtask id="T2.3.2" name="实现 abort 与 idle 等待" status="DONE" estimated_hours="3"/>
            <subtask id="T2.3.3" name="实现发送“请继续”与 UI 提示" status="DONE" estimated_hours="2"/>
            <subtask id="T2.3.4" name="重构与回归验证" status="DONE" estimated_hours="2"/>
          </subtasks>
        </task>
      </tasks>
      <gate_criteria>
        <criterion>P0 任务完成</criterion>
        <criterion>单元测试通过</criterion>
      </gate_criteria>
    </phase>

    <phase id="P3" name="状态信号与 API 支撑">
      <goal>确保 /work 能稳定获得 session status（busy|retry|idle|error）并用于 watchdog。</goal>
      <estimated_days>1</estimated_days>
      <tasks>
        <task id="T3.1" name="提供 session status 数据源" status="DONE" priority="P0" estimated_days="1">
          打通 session status busy|retry 的数据源（优先复用上游 SSE 事件映射的 session 状态），并在前端可消费。
          <acceptance_criteria>
            <criterion id="T3.1-AC1" checked="true">前端可获取 active session 的 busy|retry|idle|error 状态</criterion>
            <criterion id="T3.1-AC2" checked="true">状态变化可在合理时间内反映（避免仅依赖 UI 内部 sessionWorking）</criterion>
          </acceptance_criteria>
          <subtasks>
            <subtask id="T3.1.1" name="编写失败测试用例" status="DONE" estimated_hours="2"/>
            <subtask id="T3.1.2" name="实现后端/前端接入" status="DONE" estimated_hours="4"/>
            <subtask id="T3.1.3" name="重构与文档化" status="DONE" estimated_hours="2"/>
          </subtasks>
        </task>
      </tasks>
      <gate_criteria>
        <criterion>watchdog 使用的 session status 信号稳定</criterion>
      </gate_criteria>
    </phase>

    <phase id="P4" name="回归测试与验收">
